# ===========================================
# Site Starter — Environment Variables
# ===========================================
# Copy to .env.local and fill in values:
#   cp .env.example .env.local

# -------------------------------------------
# TinaCMS
# -------------------------------------------
TINA_PUBLIC_IS_LOCAL=true          # Set to 'true' for local dev (filesystem), remove for production (MongoDB)
GITHUB_OWNER=                      # GitHub repo owner (e.g. aadedavid)
GITHUB_REPO=                       # GitHub repo name (e.g. my-site)
GITHUB_PERSONAL_ACCESS_TOKEN=      # GitHub PAT with Contents R/W
GITHUB_BRANCH=main                 # Branch for content commits

# -------------------------------------------
# Database
# -------------------------------------------
MONGODB_URI=                       # MongoDB Atlas connection string
MONGODB_DB_NAME=                   # Database name (e.g. my-site)

# -------------------------------------------
# Auth (NextAuth)
# -------------------------------------------
NEXTAUTH_SECRET=                   # Generate: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3010 # Dev URL (change to production URL in Vercel)
GOOGLE_CLIENT_ID=                  # Google OAuth (optional)
GOOGLE_CLIENT_SECRET=              # Google OAuth (optional)
TINA_ALLOWED_EMAILS=               # Comma-separated email whitelist for CMS access

# -------------------------------------------
# Analytics (optional)
# -------------------------------------------
NEXT_PUBLIC_GA4_ID=                # Google Analytics 4 Measurement ID
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=      # Plausible domain (e.g. example.com)

# -------------------------------------------
# Email (optional)
# -------------------------------------------
RESEND_API_KEY=                    # Resend.com API key
